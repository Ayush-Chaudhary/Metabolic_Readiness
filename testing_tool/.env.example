# Copy this file to .env and fill in your values.
# .env is git-ignored and never uploaded to Databricks.
#
# These two vars are always required:
DATABRICKS_HOST=https://adb-2008955168844352.12.azuredatabricks.net

# --- Option A: Personal Access Token (local dev) ---
# DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Option B: Service Principal with endpoint access (local dev OR Databricks App) ---
# Use a service principal that already has CAN_QUERY on the llama-3-3-70b endpoint.
# These var names are intentionally different from DATABRICKS_CLIENT_ID/SECRET
# (which Databricks Apps injects for its own managed SP — a different identity).
LLM_SP_CLIENT_ID=your-service-principal-client-id-here
LLM_SP_CLIENT_SECRET=your-service-principal-client-secret-here
